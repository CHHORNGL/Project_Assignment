      ]
    },
    {
      "id": 9,
      "source_title": "Farming Systems and Poverty - Mixed Farming System (Central Europe)",
      "source_org": "FAO",
      "publication_year": null,
      "source_type": "Report chapter",
      "source_url": "https://www.fao.org/3/Y1860E/y1860e06.htm",
      "accessed_at": "2026-02-04",
      "facts": [
        {
          "id": 52,
          "source_id": 9,
          "topic": "statistic",
          "region": "Central Europe (EU accession countries)",
          "fact_text": "The Mixed Farming System in Central Europe covers an estimated 85 million hectares, mainly in the moist subhumid agro-ecological zone.",
          "metric_value": 85.0,
          "metric_unit": "million ha",
          "metric_year": null
        },
        {
          "id": 53,
          "source_id": 9,
          "topic": "statistic",
          "region": "Central Europe (EU accession countries)",
          "fact_text": "Rural populations are estimated at about 25-35% of total population and are declining.",
          "metric_value": null,
          "metric_unit": null,
          "metric_year": null
        },
        {
          "id": 54,
          "source_id": 9,
          "topic": "statistic",
          "region": "Central Europe (EU accession countries)",
          "fact_text": "Agricultural population in the system is about 16 million.",
          "metric_value": 16.0,
          "metric_unit": "million people",
          "metric_year": null
        },
        {
          "id": 55,
          "source_id": 9,
          "topic": "statistic",
          "region": "Central Europe (EU accession countries)",
          "fact_text": "Most of the 35 million ha of crop area is dedicated to wheat, maize, oil crops and barley, with smaller areas of fruit and vegetables.",
          "metric_value": 35.0,
          "metric_unit": "million ha",
          "metric_year": null
        },
        {
          "id": 56,
          "source_id": 9,
          "topic": "statistic",
          "region": "Central Europe (EU accession countries)",
          "fact_text": "There are an estimated 14 million head of cattle within the system.",
          "metric_value": 14.0,
          "metric_unit": "million head",
          "metric_year": null
        },
        {
          "id": 57,
          "source_id": 9,
          "topic": "statistic",
          "region": "Central Europe (EU accession countries)",
          "fact_text": "Total population of the farming system is about 99 million.",
          "metric_value": 99.0,
          "metric_unit": "million people",
          "metric_year": null
        },
        {
          "id": 58,
          "source_id": 9,
          "topic": "statistic",
          "region": "Central Europe (EU accession countries)",
          "fact_text": "Rural population within the system is about 36 million.",
          "metric_value": 36.0,
          "metric_unit": "million people",
          "metric_year": null
        }
      ]
    },
    {
      "id": 10,
      "source_title": "Farming Systems and Poverty - East Asia and Pacific",
