# ===============================
# FLASK
# ===============================
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-string

# ===============================
# DATABASE (PostgreSQL)
# ===============================
DB_TYPE=postgresql
DB_DRIVER=psycopg2

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=AssExpertsystem
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password

# ✅ SQLAlchemy connection string (USE THIS ONLY)
DATABASE_URL=postgresql+psycopg2://your_user:your_password@localhost:5432/AssExpertsystem

# ===============================
# SQLALCHEMY
# ===============================
SQLALCHEMY_TRACK_MODIFICATIONS=False
SQLALCHEMY_ECHO=False

# ===============================
# SECURITY
# ===============================
PASSWORD_HASH_METHOD=pbkdf2:sha256
TOKEN_EXPIRE_MINUTES=60

# ===============================
# GOOGLE OAUTH
# ===============================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ===============================
# SMTP EMAIL (GMAIL)
# ===============================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_gmail_address_here@gmail.com
MAIL_PASSWORD=your_gmail_app_password_here
MAIL_DEFAULT_SENDER=your_gmail_address_here@gmail.com

# ===============================
# OPENAI
# ===============================
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ===============================
# WEATHER INTELLIGENCE
# ===============================
WEATHER_PROVIDER_BASE_URL=https://api.open-meteo.com/v1/forecast
WEATHER_CACHE_TTL_SECONDS=600
WEATHER_STALE_TTL_SECONDS=21600
WEATHER_REQUEST_TIMEOUT_SECONDS=6

# ===============================
# DYNAMIC THEME SEASONAL EVENTS
# ===============================
THEME_EVENTS_PROVIDER=auto
THEME_EVENTS_DEFAULT_COUNTRY=KH
CALENDARIFIC_API_KEY=

# ===============================
# THEME ANIMATION AUTO SYSTEM
# ===============================
THEME_ANIMATION_CDN_PROVIDER=auto
THEME_ANIMATION_MAX_BYTES=2097152
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_UPLOAD_FOLDER=agri-theme-animations

# ===============================
# FILE UPLOADS
# ===============================
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

# ===============================
# LOGGING
# ===============================
LOG_LEVEL=INFO
